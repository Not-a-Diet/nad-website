HOST=localhost
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified

# Local-only token for `yarn seed:dev`. Create in admin → Settings → API Tokens.
# NEVER commit a real value. NEVER set this in production.
SEED_DEV_TOKEN=

# Optional: override target Strapi URL (default http://localhost:1337). Localhost only.
# STRAPI_URL=http://localhost:1337

# --- Production (Railway) -----------------------------------------------------
# Local dev leaves DATABASE_CLIENT unset → falls back to sqlite.
# On Railway set DATABASE_CLIENT=postgres and reference the Postgres plugin URL:
#   DATABASE_CLIENT=postgres
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
#   DATABASE_SSL=true
#   DATABASE_SSL_REJECT_UNAUTHORIZED=false
#   STRAPI_URL=https://cms.notadiet.life
#   FRONTEND_URL=https://www.notadiet.life
#   NODE_ENV=production
