{
  "collectionName": "components_elements_reviews",
  "info": {
    "name": "Review",
    "displayName": "Review",
    "icon": "star",
    "description": "A single customer review: author, rating, comment and the platform it came from."
  },
  "options": {},
  "attributes": {
    "authorName": {
      "type": "string",
      "required": true
    },
    "date": {
      "type": "date"
    },
    "rating": {
      "type": "integer",
      "default": 5,
      "min": 1,
      "max": 5,
      "required": true
    },
    "comment": {
      "type": "text",
      "required": true
    },
    "platform": {
      "type": "enumeration",
      "enum": ["google", "trustpilot", "instagram", "facebook"],
      "default": "google",
      "required": true
    },
    "sourceUrl": {
      "type": "string"
    },
    "avatar": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    }
  }
}
