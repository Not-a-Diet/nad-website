{
  "name": "nad-website",
  "private": true,
  "packageManager": "yarn@4.14.1",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "yarn clear && concurrently \"yarn workspace frontend dev\" \"yarn workspace backend develop\"",
    "frontend": "yarn workspace frontend dev",
    "backend": "yarn workspace backend develop",
    "clear": "rm -rf frontend/.next frontend/cache",
    "clean:setup": "rm -rf node_modules frontend/node_modules backend/node_modules && yarn install",
    "setup": "yarn install",
    "build": "yarn workspace frontend build",
    "lint": "yarn workspace frontend lint",
    "test": "yarn workspace frontend test",
    "test:watch": "yarn workspace frontend test:watch",
    "seed": "yarn workspace backend strapi import -f ../nad-database.tar.gz",
    "seed:dev": "yarn workspace backend seed:dev",
    "seed:dev:all": "yarn workspace backend seed:dev:all",
    "export": "yarn workspace backend strapi export --no-encrypt -f ../nad-database.tar.gz",
    "repo:upstream": "git fetch upstream && git merge upstream/main"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "npm-check-updates": "^16.14.15"
  },
  "resolutions": {
    "wrap-ansi@^7.0.0": "7.0.0",
    "@casl/ability": ">=6.7.5",
    "axios": ">=1.15.0",
    "form-data": ">=4.0.4",
    "handlebars": ">=4.7.9",
    "elliptic": ">=6.6.1",
    "braces": ">=3.0.3",
    "cross-spawn": ">=7.0.5",
    "lodash": ">=4.17.21",
    "lodash-es": ">=4.17.21",
    "minimatch": ">=9.0.5",
    "picomatch": ">=4.0.2",
    "tar": ">=6.2.1",
    "tar-fs": ">=3.0.6",
    "jws": ">=4.0.0",
    "rollup": ">=3.29.5",
    "serialize-javascript": ">=6.0.2"
  }
}
